{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "types": [
      "@cloudflare/workers-types",
      "@cloudflare/vitest-pool-workers/types"
    ]
  },
  "include": [
    "src/**/*.ts",
    "vite.config.ts",
    "vitest.config.ts",
    "test/**/*.ts"
  ]
}
